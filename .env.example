BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
BEEHIIV_SEND_WELCOME_EMAIL=false
# Optional: on, off, or not_set. Leave blank to use the publication default.
BEEHIIV_DOUBLE_OPT_OVERRIDE=

# Server-only Supabase ledger config. Never expose the service role key in client code.
NUTRI_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NUTRI_SUPABASE_SERVICE_ROLE_KEY=

# Optional production/base URL and stable HMAC secret for short invite links.
NUTRI_SITE_URL=https://trynutri.app
REFERRAL_LINK_SECRET=

# Optional future beehiiv automations. These require beehiiv automation access
# and should be "Add by API" automations.
BEEHIIV_WELCOME_AUTOMATION_ID=
BEEHIIV_REFERRAL_MILESTONE_AUTOMATION_ID=
